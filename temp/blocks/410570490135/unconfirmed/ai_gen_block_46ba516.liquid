{% doc %}
  @prompt
    Create a Buy Now button block for the homepage that links directly to a product and takes the customer straight to checkout. The button should be customizable (text, color, product link), visually prominent, and mobile-friendly. It should bypass the cart and trigger direct checkout when clicked.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-buy-now-button-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-buy-now-button__container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    width: {{ block.settings.desktop_width_percent }}%;
    margin: 0 auto;
  }

  .ai-buy-now-button__link-{{ ai_gen_id }} {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    transition: all 0.3s ease;
    cursor: pointer;
    text-align: center;
    width: 100%;
    max-width: {{ block.settings.button_max_width }}px;
    box-shadow: 0 {{ block.settings.button_shadow_vertical }}px {{ block.settings.button_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.button_shadow_opacity }});
  }

  .ai-buy-now-button__link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
    box-shadow: 0 {{ block.settings.button_shadow_vertical | plus: 2 }}px {{ block.settings.button_shadow_blur | plus: 4 }}px rgba(0, 0, 0, {{ block.settings.button_shadow_opacity | times: 1.5 }});
  }

  .ai-buy-now-button__icon-{{ ai_gen_id }} {
    margin-left: 8px;
    width: 18px;
    height: 18px;
    display: inline-block;
  }

  @media screen and (max-width: 749px) {
    .ai-buy-now-button__container-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-buy-now-button__link-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_padding | times: 0.9 }}px {{ block.settings.button_padding | times: 1.6 }}px;
    }
  }
{% endstyle %}

<buy-now-button-{{ ai_gen_id }} class="ai-buy-now-button-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-buy-now-button__container-{{ ai_gen_id }}">
    {% if block.settings.product != blank %}
      <a
        href="/cart/{{ block.settings.product.selected_or_first_available_variant.id }}:1?return_to=/checkout"
        class="ai-buy-now-button__link-{{ ai_gen_id }}"
        data-product-id="{{ block.settings.product.id }}"
        data-variant-id="{{ block.settings.product.selected_or_first_available_variant.id }}"
      >
        {{ block.settings.button_text }}
        {% if block.settings.show_icon %}
          <span class="ai-buy-now-button__icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </span>
        {% endif %}
      </a>
    {% else %}
      <a
        href="#"
        class="ai-buy-now-button__link-{{ ai_gen_id }}"
        style="opacity: 0.5; cursor: not-allowed;"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</buy-now-button-{{ ai_gen_id }}>

<script>
  (function() {
    class BuyNowButton{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const link = this.querySelector('.ai-buy-now-button__link-{{ ai_gen_id }}');
        
        if (!link || !link.dataset.productId) return;

        link.addEventListener('click', (e) => {
          e.preventDefault();
          
          const variantId = link.dataset.variantId;
          
          if (!variantId) {
            console.error('No variant ID found');
            return;
          }

          const formData = {
            items: [{
              id: variantId,
              quantity: 1
            }]
          };

          fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData)
          })
          .then(response => response.json())
          .then(data => {
            window.location.href = '/checkout';
          })
          .catch((error) => {
            console.error('Error:', error);
            window.location.href = '/cart/' + variantId + ':1?return_to=/checkout';
          });
        });
      }
    }

    customElements.define('buy-now-button-{{ ai_gen_id }}', BuyNowButton{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Buy now button",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "header",
      "content": "Button content"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Buy Now"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show arrow icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background color",
      "default": "#cea887"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#FDFBF7"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border color",
      "default": "#cea887"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Hover background color",
      "default": "#b89570"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#FDFBF7"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Hover border color",
      "default": "#b89570"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "button_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "Padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "button_max_width",
      "label": "Maximum width",
      "min": 200,
      "max": 600,
      "step": 20,
      "unit": "px",
      "default": 400
    },
    {
      "type": "header",
      "content": "Button shadow"
    },
    {
      "type": "range",
      "id": "button_shadow_opacity",
      "label": "Shadow opacity",
      "min": 0,
      "max": 0.5,
      "step": 0.1,
      "default": 0.2
    },
    {
      "type": "range",
      "id": "button_shadow_vertical",
      "label": "Shadow vertical offset",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "button_shadow_blur",
      "label": "Shadow blur",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Buy now button"
    }
  ]
}
{% endschema %}
