{% doc %}
  @prompt
    Add a "Buy Now" button inside a slideshow slide section. The button should link to a product and take the customer directly to checkout. It should be styled to match the theme's button styles and be positioned within the slide content area., Add a "Buy Now" button inside a slideshow slide section. The button should link to a product and take the customer directly to checkout. It should be styled to match the theme's button styles and be positioned within the slide content area.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slideshow-slide-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.slide_height_desktop }}px;
    display: block;
    overflow: hidden;
  }

  .ai-slideshow-slide__image-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .ai-slideshow-slide__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ block.settings.image_position }};
  }

  .ai-slideshow-slide__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-slideshow-slide__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-slideshow-slide__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
  }

  .ai-slideshow-slide__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.content_vertical_alignment }};
    align-items: {{ block.settings.content_horizontal_alignment }};
    padding: 40px;
    text-align: {{ block.settings.text_alignment }};
    max-width: {{ block.settings.content_max_width }}px;
    {% if block.settings.content_horizontal_alignment == 'center' %}
      margin: 0 auto;
    {% elsif block.settings.content_horizontal_alignment == 'flex-end' %}
      margin-left: auto;
    {% endif %}
  }

  .ai-slideshow-slide__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-slideshow-slide__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 24px;
    line-height: 1.5;
  }

  .ai-slideshow-slide__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border: {{ settings.buttons_border_thickness }}px solid {{ block.settings.button_background }};
    border-radius: {{ settings.buttons_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 {{ settings.buttons_shadow_vertical_offset }}px {{ settings.buttons_shadow_blur }}px rgba(0, 0, 0, {{ settings.buttons_shadow_opacity | divided_by: 100.0 }});
  }

  .ai-slideshow-slide__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_background }};
    transform: translateY(-2px);
  }

  .ai-slideshow-slide__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 6px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-slide-{{ ai_gen_id }} {
      height: {{ block.settings.slide_height_mobile }}px;
    }

    .ai-slideshow-slide__content-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-slideshow-slide__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-slideshow-slide__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.85 }}px;
    }

    .ai-slideshow-slide__button-{{ ai_gen_id }} {
      padding: 12px 24px;
      font-size: 14px;
    }
  }
{% endstyle %}

<slideshow-slide-{{ ai_gen_id }}
  class="ai-slideshow-slide-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-slideshow-slide__image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        class="ai-slideshow-slide__image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-slideshow-slide__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
    
    {% if block.settings.show_overlay %}
      <div class="ai-slideshow-slide__overlay-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>

  <div class="ai-slideshow-slide__content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-slideshow-slide__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="ai-slideshow-slide__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
    {% endif %}

    {% if block.settings.product != blank %}
      <a
        href="/cart/add?id={{ block.settings.product.selected_or_first_available_variant.id }}&quantity=1&return_to=/checkout"
        class="ai-slideshow-slide__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% else %}
      <div class="ai-slideshow-slide__empty-state-{{ ai_gen_id }}">
        Next, select a product for the Buy Now button
      </div>
    {% endif %}
  </div>
</slideshow-slide-{{ ai_gen_id }}>

<script>
  (function() {
    class SlideshowSlide{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const button = this.querySelector('.ai-slideshow-slide__button-{{ ai_gen_id }}');
        
        if (button) {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            const href = button.getAttribute('href');
            
            if (href) {
              window.location.href = href;
            }
          });
        }
      }
    }

    customElements.define('slideshow-slide-{{ ai_gen_id }}', SlideshowSlide{{ ai_gen_id }});
  })();
</script>

