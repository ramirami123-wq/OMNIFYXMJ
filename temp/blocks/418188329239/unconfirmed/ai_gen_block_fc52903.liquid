{% doc %}
  @prompt
    2 gif
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dual-gif-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-dual-gif-wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-dual-gif-item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-dual-gif-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-dual-gif-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.border_radius }}px;
    position: relative;
  }

  .ai-dual-gif-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-dual-gif-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-dual-gif-caption-{{ ai_gen_id }} {
    margin-top: {{ block.settings.caption_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.caption_color }};
    font-size: {{ block.settings.caption_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-dual-gif-wrapper-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap | times: 0.7 }}px;
    }

    .ai-dual-gif-container-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<dual-gif-block-{{ ai_gen_id }} class="ai-dual-gif-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-dual-gif-wrapper-{{ ai_gen_id }}">
    <div class="ai-dual-gif-item-{{ ai_gen_id }}">
      {% if block.settings.gif_1 %}
        <img
          src="{{ block.settings.gif_1 | image_url: width: 1000 }}"
          alt="{{ block.settings.gif_1.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.gif_1.width }}"
          height="{{ block.settings.gif_1.height }}"
          class="ai-dual-gif-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-dual-gif-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-dual-gif-empty-state-{{ ai_gen_id }}">
            Add first GIF
          </div>
        </div>
      {% endif %}
      {% if block.settings.caption_1 != blank %}
        <div class="ai-dual-gif-caption-{{ ai_gen_id }}">
          {{ block.settings.caption_1 }}
        </div>
      {% endif %}
    </div>

    <div class="ai-dual-gif-item-{{ ai_gen_id }}">
      {% if block.settings.gif_2 %}
        <img
          src="{{ block.settings.gif_2 | image_url: width: 1000 }}"
          alt="{{ block.settings.gif_2.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.gif_2.width }}"
          height="{{ block.settings.gif_2.height }}"
          class="ai-dual-gif-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-dual-gif-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-dual-gif-empty-state-{{ ai_gen_id }}">
            Add second GIF
          </div>
        </div>
      {% endif %}
      {% if block.settings.caption_2 != blank %}
        <div class="ai-dual-gif-caption-{{ ai_gen_id }}">
          {{ block.settings.caption_2 }}
        </div>
      {% endif %}
    </div>
  </div>
</dual-gif-block-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Dual GIF display",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "First GIF"
    },
    {
      "type": "image_picker",
      "id": "gif_1",
      "label": "GIF image"
    },
    {
      "type": "text",
      "id": "caption_1",
      "label": "Caption"
    },
    {
      "type": "header",
      "content": "Second GIF"
    },
    {
      "type": "image_picker",
      "id": "gif_2",
      "label": "GIF image"
    },
    {
      "type": "text",
      "id": "caption_2",
      "label": "Caption"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Space between GIFs",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "1/1",
          "label": "Square (1:1)"
        },
        {
          "value": "4/3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "16/9",
          "label": "Widescreen (16:9)"
        },
        {
          "value": "3/4",
          "label": "Portrait (3:4)"
        }
      ],
      "default": "1/1"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Caption style"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "caption_size",
      "label": "Caption size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "caption_spacing",
      "label": "Caption spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Caption color",
      "default": "#121212"
    }
  ],
  "presets": [
    {
      "name": "Dual GIF display"
    }
  ]
}
{% endschema %}