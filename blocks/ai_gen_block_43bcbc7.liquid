{% doc %}
  @prompt
    gif block, I WANT TEXT TO BE PLACED ON TOP OF GIF NOT BELOW
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gif-block-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-gif-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    position: relative;
  }

  .ai-gif-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
  }

  .ai-gif-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-gif-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-gif-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-gif-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-gif-caption-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.caption_vertical_position }}%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    text-align: {{ block.settings.caption_alignment }};
    color: {{ block.settings.caption_color }};
    font-size: {{ block.settings.caption_size }}px;
    font-weight: {{ block.settings.caption_weight }};
    background-color: {{ block.settings.caption_background }};
    padding: {{ block.settings.caption_padding }}px;
    border-radius: {{ block.settings.caption_border_radius }}px;
    z-index: 2;
  }

  @media screen and (max-width: 749px) {
    .ai-gif-container-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-gif-caption-{{ ai_gen_id }} {
      font-size: {{ block.settings.caption_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<gif-block-{{ ai_gen_id }} class="ai-gif-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-gif-container-{{ ai_gen_id }}">
    <div class="ai-gif-wrapper-{{ ai_gen_id }}">
      {% if block.settings.gif_image %}
        <img
          src="{{ block.settings.gif_image | image_url }}"
          alt="{{ block.settings.gif_image.alt | escape }}"
          loading="lazy"
          class="ai-gif-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-gif-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-gif-empty-state-{{ ai_gen_id }}">
            Next, add a GIF image
          </div>
        </div>
      {% endif %}

      {% if block.settings.caption != blank %}
        <div class="ai-gif-caption-{{ ai_gen_id }}">
          {{ block.settings.caption }}
        </div>
      {% endif %}
    </div>
  </div>
</gif-block-{{ ai_gen_id }}>

<script>
  (function() {
    class GifBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
        const img = this.querySelector('.ai-gif-image-{{ ai_gen_id }}');
        if (img) {
          img.addEventListener('load', function() {
            img.style.opacity = '1';
          });
        }
      }
    }

    customElements.define('gif-block-{{ ai_gen_id }}', GifBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "GIF block",
  "settings": [
    {
      "type": "header",
      "content": "GIF image"
    },
    {
      "type": "image_picker",
      "id": "gif_image",
      "label": "GIF image"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Shadow"
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "label": "Shadow opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.1
    },
    {
      "type": "range",
      "id": "shadow_vertical",
      "label": "Vertical offset",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "shadow_blur",
      "label": "Blur",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Caption"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption text"
    },
    {
      "type": "select",
      "id": "caption_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "caption_vertical_position",
      "label": "Vertical position",
      "min": 10,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "caption_size",
      "label": "Text size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "caption_weight",
      "label": "Text weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "caption_background",
      "label": "Background color",
      "default": "rgba(0, 0, 0, 0.5)"
    },
    {
      "type": "range",
      "id": "caption_padding",
      "label": "Padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "caption_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "GIF block"
    }
  ]
}
{% endschema %}